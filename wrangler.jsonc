{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "acc-4-pf",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "_site",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ pageTitle or title }} | {{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ pageTitle or title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="ACC4PF">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle or title }}">
  <meta name="twitter:description" content="{{ description or site.description }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="/css/main.css">

  <!-- Organization Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "ACC4PF — ACC Access for Pflugerville",
    "url": "https://acc4pf.com",
    "description": "Community-led campaign to bring Austin Community College in-district for Pflugerville ISD residents."
  }
  </script>

  {% if schema %}
  <script type="application/ld+json">
  {{ schema | safe }}
  </script>
  {% endif %}

  {% block head %}{% endblock %}
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <!-- Petition / Vote bar -->
  <div class="petition-bar">
    <span>Help get ACC on the November ballot.</span>
    <a href="{{ site.cta_primary_url }}">{{ site.cta_primary_text }} &rarr;</a>
  </div>

  <!-- Site Header -->
  <header class="site-header">
    <div class="container">
      <a href="/" class="site-logo">ACC<span>4</span>PF</a>
      <button class="nav-toggle" aria-label="Toggle navigation" onclick="document.querySelector('.site-nav').classList.toggle('open')">
        <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/calculator/">Calculator</a>
        <a href="/why-this-matters/">Why it matters</a>
        <a href="/workforce-and-trades/">Workforce</a>
        <a href="/faq/">FAQ</a>
        <a href="/outside-city-limits/">Outside city limits?</a>
        <a href="{{ site.cta_primary_url }}" class="cta-btn">{{ site.cta_primary_text }}</a>
      </nav>
    </div>
  </header>

  <main id="main">
    {{ content | safe }}
  </main>

  <!-- CTA Strip -->
  {% if not hideCta %}
  <section class="cta-strip">
    <div class="container">
      <h2>Pflugerville pays 3.4x more. Help fix that.</h2>
      <p>Calculate your cost, then sign the petition to put this on the November ballot.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href="/calculator/" class="btn btn-white">Calculate your cost</a>
        <a href="{{ site.cta_primary_url }}" class="btn btn-primary">{{ site.cta_primary_text }}</a>
      </div>
    </div>
  </section>
  {% endif %}

  <!-- Footer -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>Learn</h4>
          <a href="/why-this-matters/">Why this matters</a>
          <a href="/calculator/">Cost calculator</a>
          <a href="/faq/">FAQ</a>
          <a href="/myth-vs-fact/">Myth vs. fact</a>
          <a href="/research/">Research &amp; sources</a>
        </div>
        <div class="footer-col">
          <h4>Who benefits</h4>
          <a href="/workforce-and-trades/">Workforce &amp; trades</a>
          <a href="/students-and-families/">Students &amp; families</a>
          <a href="/career-change/">Career changers</a>
          <a href="/employers/">Employers</a>
          <a href="/outside-city-limits/">Outside city limits?</a>
        </div>
        <div class="footer-col">
          <h4>Take action</h4>
          <a href="{{ site.cta_primary_url }}">{{ site.cta_primary_text }}</a>
          <a href="/volunteer/">Volunteer</a>
          <a href="/community-voices/">Community voices</a>
          <a href="/about/">About the campaign</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>{{ site.disclaimer }} &copy; {% year %} ACC4PF. <a href="/research/">Sources</a> for all claims.</p>
      </div>
    </div>
  </footer>

  <script src="/js/main.js" defer></script>
</body>
</html>
